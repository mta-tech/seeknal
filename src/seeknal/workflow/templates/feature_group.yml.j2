kind: feature_group
name: {{ name }}
description: "{{ description | default('Feature group for ML models') }}"
owner: "{{ owner | default('ml-team@example.com') }}"
tags: {{ tags | default(['features']) | tojson }}
materialization:
  type: view
entity:
  name: {{ entity_name | default('customer') }}
  join_keys: {{ join_keys | default(['customer_id']) | tojson }}
inputs:
  - ref: transform.customer_360
transform: |
  SELECT
    customer_id,
    total_orders AS frequency,
    total_spend AS monetary,
    CAST(total_spend / NULLIF(total_orders, 0) AS DOUBLE) AS avg_order_value,
    DATE_DIFF('day', CAST(last_order_date AS DATE), CURRENT_DATE) AS recency_days
  FROM source
features:
  frequency:
    description: "Total number of orders"
    dtype: int
  monetary:
    description: "Total spend amount"
    dtype: float
  avg_order_value:
    description: "Average order value"
    dtype: float
  recency_days:
    description: "Days since last order"
    dtype: int
