"""
Model: {{ name }}

Generated by: seeknal draft model {{ name }} --python

Usage:
  1. Edit ctx.ref() to point to your feature table or upstream transform
  2. Implement your model logic in the transform function
  3. Return the FULL DataFrame with all original columns + predictions
"""

from seeknal.pipeline import transform


@transform(
    name="{{ name }}",
    description="{{ description or 'ML model predictions' }}",
)
def {{ name }}(ctx):
    """
    ML model function. Runs in a subprocess — use ctx.ref() only.

    - ctx.ref("kind.name") -> Returns a plain pandas DataFrame
    - ctx.config -> Profile configuration

    Return the FULL DataFrame with ALL original columns + new prediction columns.
    """
    import pandas as pd
    from sklearn.cluster import KMeans
    from sklearn.preprocessing import StandardScaler

    # Load data — .to_df() converts FeatureFrame to plain DataFrame if needed
    _raw = ctx.ref("transform.customer_features")  # TODO: change to your feature source
    df = _raw.to_df() if hasattr(_raw, 'to_df') else _raw

    # Select numeric features for clustering
    feature_cols = []  # TODO: list your numeric feature columns
    for col in df.columns:
        if df[col].dtype in ('int64', 'float64') and col not in ('customer_id', 'id'):
            feature_cols.append(col)

    if not feature_cols:
        df["cluster"] = 0
        return df

    # Scale features and fit model
    X = df[feature_cols].fillna(0)
    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
    df["cluster"] = kmeans.fit_predict(X_scaled)

    # Add cluster labels
    cluster_means = df.groupby("cluster")[feature_cols].mean()
    label_map = {}
    for cluster_id in cluster_means.index:
        avg = cluster_means.loc[cluster_id].mean()
        if avg > cluster_means.mean().mean():
            label_map[cluster_id] = "high_value"
        elif avg < cluster_means.mean().mean() * 0.5:
            label_map[cluster_id] = "low_value"
        else:
            label_map[cluster_id] = "mid_value"
    df["segment_label"] = df["cluster"].map(label_map)

    return df
