"""
Model: {{ name }}

Generated by: seeknal draft model {{ name }} --python

Usage:
  1. Edit the @source to point to your feature table
  2. Edit the @transform to implement your model logic
  3. Return the FULL DataFrame with all original columns + predictions
"""

from seeknal.pipeline import source, transform


@source(name="{{ name }}_input")
def load_features(ctx):
    """Load features from upstream transform or feature group."""
    return ctx.ref("transform.customer_features")  # TODO: change to your feature source


@transform(
    name="{{ name }}",
    description="{{ description or 'ML model predictions' }}",
)
def {{ name }}(ctx):
    """
    ML model function. Receives context with:
    - ctx.ref("kind.name") -> Get upstream DataFrame
    - ctx.duckdb -> DuckDB connection
    - ctx.config -> Profile configuration

    IMPORTANT: Return the FULL DataFrame with ALL original columns + new prediction columns.
    Do NOT return only the prediction column — downstream transforms need the full row context.
    """
    import pandas as pd
    from sklearn.cluster import KMeans
    from sklearn.preprocessing import StandardScaler

    # Load feature data
    df = ctx.ref("{{ name }}_input")

    # Select numeric features for clustering
    feature_cols = []  # TODO: list your numeric feature columns
    for col in df.columns:
        if df[col].dtype in ('int64', 'float64') and col not in ('customer_id', 'id'):
            feature_cols.append(col)

    if not feature_cols:
        df["cluster"] = 0
        return df

    # Scale features and fit model
    X = df[feature_cols].fillna(0)
    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
    df["cluster"] = kmeans.fit_predict(X_scaled)

    # Add cluster labels
    cluster_means = df.groupby("cluster")[feature_cols].mean()
    label_map = {}
    for cluster_id in cluster_means.index:
        avg = cluster_means.loc[cluster_id].mean()
        if avg > cluster_means.mean().mean():
            label_map[cluster_id] = "high_value"
        elif avg < cluster_means.mean().mean() * 0.5:
            label_map[cluster_id] = "low_value"
        else:
            label_map[cluster_id] = "mid_value"
    df["segment_label"] = df["cluster"].map(label_map)

    return df
